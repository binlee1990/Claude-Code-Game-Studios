static func display_text(value: String, locale: String = "") -> String:
	var requested_locale := locale if locale != "" else current_locale
	if requested_locale == ENGLISH_LOCALE:
		return value
	var bundle: Dictionary = _DISPLAY_TEXT.get(requested_locale, {})
	return String(bundle.get(value, value))

static func translate(key: String, locale: String = "") -> String:
	var requested_locale := locale if locale != "" else current_locale
	var bundle: Dictionary = _CATALOG.get(requested_locale, {})
	if bundle.has(key):
		return String(bundle[key])
	var fallback: Dictionary = _CATALOG.get(DEFAULT_LOCALE, {})
	return String(fallback.get(key, key))

static func set_locale(locale: String) -> bool:
	if not _CATALOG.has(locale):
		return false
	current_locale = locale
	return true

static func get_locale() -> String:
	if not _CATALOG.has(current_locale):
		current_locale = DEFAULT_LOCALE
	return current_locale

static func locale_label(locale: String = "") -> String:
	var resolved := locale if locale != "" else get_locale()
	return translate("locale.%s" % resolved, resolved)

static func supported_locales() -> Array[String]:
	var locales: Array[String] = []
	for locale in _CATALOG.keys():
		locales.append(String(locale))
	locales.sort()
	return locales

static func is_supported_locale(locale: String) -> bool:
	return _CATALOG.has(locale)

static func catalog_size(locale: String = DEFAULT_LOCALE) -> int:
	return (_CATALOG.get(locale, {}) as Dictionary).size()

static func catalog_keys(locale: String = DEFAULT_LOCALE) -> Array[String]:
	var keys: Array[String] = []
	var bundle: Dictionary = _CATALOG.get(locale, {})
	for key in bundle.keys():
		keys.append(String(key))
	keys.sort()
	return keys

static func missing_keys(locale: String, against_locale: String = DEFAULT_LOCALE) -> Array[String]:
	var missing: Array[String] = []
	var bundle: Dictionary = _CATALOG.get(locale, {})
	var baseline: Dictionary = _CATALOG.get(against_locale, {})
	for key in baseline.keys():
		if not bundle.has(key):
			missing.append(String(key))
	missing.sort()
	return missing
